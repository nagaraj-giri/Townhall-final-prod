rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && data != null && data.get('role', 'CUSTOMER') == 'ADMIN';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRFQOwner(rfqId) {
      let rfqPath = /databases/$(database)/documents/rfqs/$(rfqId);
      return exists(rfqPath) && get(rfqPath).data.customerId == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /rfqs/{rfqId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quotesCount', 'status', 'acceptedQuoteId', 'searchRadius', 'matchingStopped', 'lastMatchAt', 'lastMatchTriggeredAt'])
      ); 
      allow delete: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
    }

    match /matches/{matchId} {
      // Access granted if user is signed in. Writes restricted to Admin or the RFQ owner via rfqId check.
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && isRFQOwner(request.resource.data.rfqId));
    }

    match /quotes/{quoteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.providerId == request.auth.uid || 
        isAdmin() ||
        (get(/databases/$(database)/documents/rfqs/$(resource.data.rfqId)).data.customerId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }
    
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin(); 
    }

    match /broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /provider_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /chats/{roomId} {
      function isRoomParticipant() {
        return isSignedIn() && (roomId.matches('.*' + request.auth.uid + '.*') || isAdmin());
      }

      allow read: if isRoomParticipant();
      allow update: if isRoomParticipant();
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow delete: if isAdmin();

      match /history/{messageId} {
        allow read: if isRoomParticipant();
        allow create: if isRoomParticipant() && (request.auth.uid == request.resource.data.senderId);
        allow update: if isRoomParticipant() && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        );
      }
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin();
    }

    match /emails/{emailId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}